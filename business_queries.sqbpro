<?xml version="1.0" encoding="UTF-8"?><sqlb_project><db path="retail_sales.db" readonly="0" foreign_keys="1" case_sensitive_like="0" temp_store="0" wal_autocheckpoint="1000" synchronous="2"/><attached/><window><main_tabs open="structure browser pragmas query" current="3"/></window><tab_structure><column_width id="0" width="300"/><column_width id="1" width="0"/><column_width id="2" width="100"/><column_width id="3" width="1889"/><column_width id="4" width="0"/><expanded_item id="0" parent="1"/><expanded_item id="1" parent="1"/><expanded_item id="2" parent="1"/><expanded_item id="3" parent="1"/></tab_structure><tab_browse><table title="Sales" custom_title="0" dock_id="1" table="4,5:mainSales"/><dock_state state="000000ff00000000fd00000001000000020000038d00000365fc0100000001fb000000160064006f0063006b00420072006f007700730065003101000000000000038d0000015c00ffffff0000038d0000000000000004000000040000000800000008fc00000000"/><default_encoding codec=""/><browse_table_settings><table schema="main" name="Sales" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="63"/><column index="2" value="79"/><column index="3" value="50"/><column index="4" value="92"/><column index="5" value="68"/><column index="6" value="77"/><column index="7" value="96"/><column index="8" value="101"/><column index="9" value="76"/><column index="10" value="75"/><column index="11" value="62"/><column index="12" value="104"/><column index="13" value="94"/><column index="14" value="98"/><column index="15" value="89"/><column index="16" value="153"/><column index="17" value="65"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">SELECT sales_channel, COUNT(*) AS total_orders, ROUND(SUM(net_revenue), 2) AS total_revenue, 
ROUND(AVG(net_revenue), 2) AS avg_order_value FROM sales GROUP BY sales_channel ORDER BY total_revenue DESC;

SELECT product, category, ROUND(SUM(net_revenue), 2) AS total_revenue FROM sales GROUP BY product, category 
ORDER BY total_revenue DESC LIMIT 5;

SELECT SUBSTR (order_date, 1, 7) AS year_month, ROUND (SUM(net_revenue), 2) AS monthly_revenue, 
COUNT(*)  AS order_count FROM sales GROUP BY year_month ORDER BY year_month;

SELECT  franchise, COUNT(*) AS total_orders, SUM(returned) AS returns, 
ROUND(100.0* SUM(returned)/ COUNT(*),2) AS return_rate_pct FROM sales GROUP BY franchise ORDER BY return_rate_pct DESC;

SELECT CASE WHEN day_of_week IN ('Saturday', 'Sunday') THEN 'Weekend' ELSE 'Weekday' END AS day_type, COUNT(*) AS total_orders, 
ROUND(AVG(net_revenue),2) AS avg_order_value, ROUND(AVG(customer_satisfaction),2) AS avg_satisfaction FROM sales GROUP BY day_type;

SELECT
    sales_channel,
    ROUND(AVG(net_revenue), 2) AS avg_order_value,
    ROUND(100.0 * SUM(returned) / COUNT(*), 2) AS return_rate_pct,
    ROUND(AVG(customer_satisfaction), 2) AS avg_csat,
    ROUND(100.0 * SUM(CASE WHEN discount_pct &gt; 0 THEN 1 ELSE 0 END)
          / COUNT(*), 2) AS promo_rate_pct
FROM sales
GROUP BY sales_channel
ORDER BY avg_order_value DESC;


--Comments</sql><current_tab id="0"/></tab_sql></sqlb_project>
